    "---\n",
    "## 5. 硬件执行模型——Roofline 与 FLOPs 计算"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def calc_matmul_flops(M, N, K):\n",
    "    \"\"\"[M,K] x [K,N] 的 FLOPs (2MNK)\"\"\"\n",
    "    return 2 * M * N * K\n",
    "\n",
    "def calc_memory_bytes(M, N, K, dtype_bytes=4):\n",
    "    \"\"\"读取 A[M,K] + B[K,N] + 写入 C[M,N] 的总字节\"\"\"\n",
    "    return (M*K + K*N + M*N) * dtype_bytes\n",
    "\n",
    "def arithmetic_intensity(M, N, K, dtype_bytes=4):\n",
    "    \"\"\"计算强度 = FLOPs / Bytes\"\"\"\n",
    "    flops = calc_matmul_flops(M, N, K)\n",
    "    mem = calc_memory_bytes(M, N, K, dtype_bytes)\n",
    "    return flops / mem\n",
    "\n",
    "# Qwen3-0.6B 的 Q 投影: [batch, 1024] x [1024, 2048]\n",
    "print(\"Qwen3-0.6B Q投影 GEMM [B, 1024] x [1024, 2048]:\")\n",
    "print(f\"  {'batch':<8} {'FLOPs':<15} {'Memory':<15} {'计算强度':<10} {'瓶颈'}\")\n",
    "print(f\"  {'-'*55}\")\n",
    "for B in [1, 4, 32, 256, 512]:\n",
    "    flops = calc_matmul_flops(B, 2048, 1024)\n",
    "    mem = calc_memory_bytes(B, 2048, 1024, dtype_bytes=2)\n",
    "    ai = arithmetic_intensity(B, 2048, 1024, dtype_bytes=2)\n",
    "    bottleneck = \"Compute-bound ✓\" if ai > 150 else \"Memory-bound ✗\"\n",
    "    print(f\"  {B:<8} {flops/1e6:>8.1f} MFLOPs  {mem/1e6:>8.1f} MB    {ai:>8.1f}       {bottleneck}\")\n",
    "\n",
    "print(f\"\\n  A100 roofline 拐点 ≈ 150 FLOPs/Byte\")\n",
    "print(f\"  Decode (batch=1): 严重 memory-bound — 瓶颈在带宽\")\n",
    "print(f\"  Prefill (batch=512): compute-bound — 瓶颈在算力\")"
   ]
