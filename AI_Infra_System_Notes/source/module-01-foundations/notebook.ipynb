   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2.1 Sigmoid vs Softmax——独立判断 vs 联合决策"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sigmoid: 每个元素独立判断\n",
    "logits = torch.tensor([2.0, 1.0, 0.5, -1.0])\n",
    "sigmoid_out = torch.sigmoid(logits)\n",
    "print(f"原始值:   {logits.tolist()}\")\n",
    "print(f\"Sigmoid:  {[f'{x:.3f}' for x in sigmoid_out.tolist()]}\")\n",
    "print(f\"  -> 各值独立在(0,1), 总和={sigmoid_out.sum():.3f} (不是1!)\")\n",
    "\n",
    "# Softmax: 整个向量联合决策\n",
    "softmax_out = F.softmax(logits, dim=0)\n",
    "print(f\"\\nSoftmax:  {[f'{x:.3f}' for x in softmax_out.tolist()]}\")\n",
    "print(f\"  -> 各值在(0,1), 总和={softmax_out.sum():.3f} (一定是1)\")\n",
    "\n",
    "# 演示 Temperature 的效果\n",
    "temps = [0.5, 1.0, 2.0, 5.0]\n",
    "fig, axes = plt.subplots(1, 4, figsize=(16, 3))\n",
    "for ax, T in zip(axes, temps):\n",
    "    probs = F.softmax(logits / T, dim=0)\n",
    "    ax.bar(range(len(logits)), probs.numpy(), color=['#FF5722','#2196F3','#4CAF50','#FFC107'])\n",
    "    ax.set_title(f'Temperature = {T}', fontweight='bold')\n",
    "    ax.set_ylim(0, 1)\n",
    "    ax.set_ylabel('概率')\n",
    "plt.suptitle('Temperature 对 Softmax 分布的影响', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "print(\"T<1: 分布更尖锐 (更确定) | T=1: 原始分布 | T>1: 分布更平滑 (更随机)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2.2 SwiGLU——现代 LLM MLP 的核心"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SwiGLU = Swish(x·W_gate) ⊙ (x·W_up) · W_down\n",
    "# 让我们手写一个微型的 SwiGLU 看看数值变化\n",
    "\n",
    "hidden_dim, intermediate_dim = 8, 24  # 3x\n",
    "\n",
    "# 模拟一次 SwiGLU forward\n",
    "x = torch.randn(1, hidden_dim)\n",
    "W_gate = torch.randn(hidden_dim, intermediate_dim)\n",
    "W_up   = torch.randn(hidden_dim, intermediate_dim)\n",
    "W_down = torch.randn(intermediate_dim, hidden_dim)\n",
    "\n",
    "gate = F.silu(x @ W_gate)   # Swish 门控信号\n",
    "up   = x @ W_up              # 信息流\n",
    "gated = gate * up             # 逐元素门控！\n",
    "output = gated @ W_down       # 投影回 hidden_dim\n",
    "\n",
    "print(f\"输入:     {x.shape}\")\n",
    "print(f\"gate:    Swish(x·W_gate) → {gate.shape}  (门控信号, 0~1+范围)\")\n",
    "print(f\"up:      x·W_up         → {up.shape}    (信息流)\")\n",
    "print(f\"gated:   gate ⊙ up      → {gated.shape}  (选择性放行!)\")\n",
    "print(f\"output:  gated·W_down    → {output.shape} (最终输出)\")\n",
    "print(f\"\\n门控信号统计: min={gate.min():.2f}, max={gate.max():.2f}, mean={gate.mean():.2f}\")\n",
    "print(f\"约 {((gate > 0.01) & (gate < 0.99)).float().mean()*100:.0f}% 的值在部分门控状态 (0.01~0.99)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. 归一化——自己实现 BatchNorm / LayerNorm / RMSNorm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def my_batchnorm(x, gamma, beta, eps=1e-5):\n",
    "    \"\"\"BatchNorm: 在 (N, H, W) 维度统计, 每个通道独立\"\"\"\n",
    "    mean = x.mean(dim=(0, 2, 3), keepdim=True)  # [1, C, 1, 1]\n",
    "    var  = x.var(dim=(0, 2, 3), keepdim=True, unbiased=False)\n",
    "    return gamma.view(1,-1,1,1) * (x - mean) / torch.sqrt(var + eps) + beta.view(1,-1,1,1)\n",
    "\n",
    "def my_layernorm(x, gamma, beta, eps=1e-5):\n",
    "    \"\"\"LayerNorm: 在 (C, H, W) 维度统计, 每个样本独立\"\"\"\n",
    "    mean = x.mean(dim=(1,2,3), keepdim=True)  # [B, 1, 1, 1]\n",
    "    var  = x.var(dim=(1,2,3), keepdim=True, unbiased=False)\n",
    "    return gamma.view(1,-1,1,1) * (x - mean) / torch.sqrt(var + eps) + beta.view(1,-1,1,1)\n",
    "\n",
    "def my_rmsnorm(x, gamma, eps=1e-6):\n",
    "    \"\"\"RMSNorm: 只做缩放, 无均值减法, 无beta\"\"\"\n",
    "    rms = torch.sqrt(torch.mean(x ** 2, dim=-1, keepdim=True) + eps)\n",
    "    return x / rms * gamma\n",
    "\n",
    "# 测试数据\n",
    "B, C, H, W = 2, 3, 4, 4\n",
    "x = torch.randn(B, C, H, W)\n",
    "gamma = torch.ones(C)\n",
    "beta  = torch.zeros(C)\n",
    "\n",
    "# 验证: 与 PyTorch 官方实现对比\n",
    "bn_my = my_batchnorm(x, gamma, beta)\n",
    "bn_pt = F.batch_norm(x, torch.zeros(C), torch.ones(C), training=True)\n",
    "print(f\"BatchNorm - 与PyTorch差异: {(bn_my - bn_pt).abs().max():.2e}\")\n",
    "\n",
    "ln_my = my_layernorm(x, gamma, beta)\n",
    "ln_pt = F.layer_norm(x, [C,H,W], weight=gamma, bias=beta)\n",
    "print(f\"LayerNorm - 与PyTorch差异: {(ln_my - ln_pt).abs().max():.2e}\")\n",
    "\n",
    "# RMSNorm 测试 (序列形状: [B, L, D])\n",
    "x_seq = torch.randn(2, 10, 64)\n",
    "rms_my = my_rmsnorm(x_seq, torch.ones(64))\n",
    "print(f\"RMSNorm  - 输出 shape: {rms_my.shape}, 均值≈{rms_my.mean():.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 可视化: 归一化前后分布对比\n",
    "x_raw = torch.randn(1000) * 3 + 2  # 均值=2, 标准差=3 的偏态分布\n",
    "\n",
    "# LayerNorm\n",
    "x_ln = (x_raw - x_raw.mean()) / x_raw.std()\n",
    "# RMSNorm\n",
    "rms = torch.sqrt(torch.mean(x_raw ** 2))\n",
    "x_rms = x_raw / rms\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 3))\n",
    "axes[0].hist(x_raw.numpy(), bins=50, color='#FF5722', alpha=0.7)\n",
    "axes[0].set_title(f'原始: μ={x_raw.mean():.2f}, σ={x_raw.std():.2f}')\n",
    "axes[1].hist(x_ln.numpy(), bins=50, color='#2196F3', alpha=0.7)\n",
    "axes[1].set_title(f'LayerNorm后: μ={x_ln.mean():.2f}, σ={x_ln.std():.2f}')\n",
    "axes[2].hist(x_rms.numpy(), bins=50, color='#4CAF50', alpha=0.7)\n",
    "axes[2].set_title(f'RMSNorm后: RMS≈{torch.sqrt(torch.mean(x_rms**2)):.2f}')\n",
    "plt.suptitle('归一化的效果', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. 梯度与反向传播——手算验证"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 手动 SGD: Loss = (wx - target)^2\n",
    "# 梯度: dL/dw = 2(wx - target) * x\n",
    "\n",
    "w = torch.tensor([0.0], requires_grad=False)\n",
    "x = torch.tensor([2.0])\n",
    "target = torch.tensor([3.0])\n",
    "\n",
    "lr = 0.1\n",
    "history_w = []\n",
    "history_loss = []\n",
    "\n",
    "print(\"手动 SGD 训练 (手算梯度):\")\n",
    "print(f\"  初始: w={w.item():.4f}\")\n",
    "for step in range(5):\n",
    "    y_pred = w * x\n",
    "    loss = (y_pred - target) ** 2\n",
    "    grad = 2 * (y_pred - target) * x  # 手算梯度!\n",
    "    w = w - lr * grad\n",
    "    history_w.append(w.item())\n",
    "    history_loss.append(loss.item())\n",
    "    print(f\"  Step {step+1}: w={w.item():.4f}, loss={loss.item():.4f}, grad={grad.item():.4f}\")\n",
    "\n",
    "print(f\"\\n  理论最优 w = target/x = 1.5\")\n",
    "print(f\"  实际收敛 w = {w.item():.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# PyTorch autograd 自动求导——对比\n",
    "w_auto = torch.tensor([0.0], requires_grad=True)\n",
    "optimizer = torch.optim.SGD([w_auto], lr=0.1)\n",
    "\n",
    "print(\"PyTorch autograd 训练:\")\n",
    "for step in range(5):\n",
    "    loss = (w_auto * x - target) ** 2\n",
    "    optimizer.zero_grad()\n",
    "    loss.backward()  # 自动计算梯度!\n",
    "    optimizer.step()\n",
    "    print(f\"  Step {step+1}: w={w_auto.item():.4f}, loss={loss.item():.4f}, autograd_grad={w_auto.grad.item():.4f}\")\n",
    "\n",
    "# 可视化收敛过程\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 3.5))\n",
    "ax1.plot(history_w, marker='o', linewidth=2, color='#2196F3', markersize=8)\n",
    "ax1.axhline(y=1.5, color='red', linestyle='--', label='最优值 w=1.5')\n",
    "ax1.set_xlabel('Step'), ax1.set_ylabel('w'), ax1.set_title('参数收敛')\n",
    "ax1.legend(), ax1.grid(True, alpha=0.3)\n",
    "ax2.plot(history_loss, marker='o', linewidth=2, color='#FF5722', markersize=8)\n",
    "ax2.set_xlabel('Step'), ax2.set_ylabel('Loss'), ax2.set_title('损失下降')\n",
    "ax2.grid(True, alpha=0.3)\n",
    "plt.tight_layout(), plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 演示"死亡 ReLU"——为什么激活函数的导数不能为0\n",
    "torch.manual_seed(42)\n",
    "\n",
    "# 一个简单的3层网络, 分别用 ReLU 和 Swish\n",
    "class TinyNet(nn.Module):\n",
    "    def __init__(self, activation):\n",
    "        super().__init__()\n",
    "        self.fc1 = nn.Linear(10, 10)\n",
    "        self.fc2 = nn.Linear(10, 10)\n",
    "        self.act = activation\n",
    "    def forward(self, x):\n",
    "        x = self.act(self.fc1(x))\n",
    "        x = self.act(self.fc2(x))\n",
    "        return x.sum()\n",
    "\n",
    "# 输入全为负数——触发 ReLU 死亡区\n",
    "x = -torch.randn(1, 10)  # 全是负数!\n",
    "\n",
    "for name, act in [(\"ReLU\", nn.ReLU()), (\"Swish\", nn.SiLU())]:\n",
    "    model = TinyNet(act)\n",
    "    y = model(x)\n",
    "    y.backward()\n",
    "    \n",
    "    # 检查 fc1 的梯度\n",
    "    grad_norm = model.fc1.weight.grad.norm().item()\n",
    "    print(f\"{name}: fc1.weight.grad 的 L2 范数 = {grad_norm:.6f}\")\n",
    "    if grad_norm == 0:\n",
    "        print(f\"  -> {name} 的梯度完全消失了! fc1 的参数无法更新!\")\n",
    "    else:\n",
    "        print(f\"  -> {name} 保留了梯度, fc1 可以继续学习\")"
   ]
  },
