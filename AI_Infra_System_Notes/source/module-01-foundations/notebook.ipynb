    "## 8. SIMD——\"一次处理多个\"的直观演示"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 虽然 Python 没有真正的 SIMD, 但可以用向量化操作演示思想\n",
    "\n",
    "N = 10_000_000\n",
    "a = np.random.randn(N).astype(np.float32)\n",
    "b = np.random.randn(N).astype(np.float32)\n",
    "\n",
    "# 模拟标量操作 (Python loop)\n",
    "import time\n",
    "t0 = time.time()\n",
    "c_scalar = np.zeros(N, dtype=np.float32)\n",
    "for i in range(min(N, 100000)):  # 只跑10万次, 全跑太慢\n",
    "    c_scalar[i] = a[i] + b[i]\n",
    "scalar_time = time.time() - t0\n",
    "scalar_per_element = scalar_time / 100000 * 1e9\n",
    "\n",
    "# 向量化操作 (相当于 SIMD)\n",
    "t0 = time.time()\n",
    "c_vec = a + b\n",
    "vec_time = time.time() - t0\n",
    "vec_per_element = vec_time / N * 1e9\n",
    "\n",
    "print(f\"Python loop (模拟标量):  {scalar_time*1000:.1f}ms for 100K → {scalar_per_element:.1f}ns/element\")\n",
    "print(f\"NumPy 向量化 (模拟SIMD): {vec_time*1000:.1f}ms for {N//1_000_000}M → {vec_per_element:.2f}ns/element\")\n",
    "print(f\"\\n加速比: ~{scalar_per_element/vec_per_element:.0f}x\")\n",
    "print(f\"\\n在CPU上, AVX-512 一条指令同时处理 16 个 FP32\")\n",
    "print(f\"在GPU上, 一个 warp 同时运行 32 个线程\")\n",
    "print(f\"这就是 SIMD / SIMT 的力量 —— 并行度 = 免费的性能\")"
   ]
