    "---\n",
    "## 7. 学习率调度——Warmup + Cosine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def warmup_cosine_schedule(step, warmup_steps, total_steps, lr_max=1e-3, lr_min=1e-5):\n",
    "    if step < warmup_steps:\n",
    "        return lr_max * step / warmup_steps  # 线性 warmup\n",
    "    progress = (step - warmup_steps) / (total_steps - warmup_steps)\n",
    "    return lr_min + 0.5 * (lr_max - lr_min) * (1 + np.cos(np.pi * progress))\n",
    "\n",
    "total_steps, warmup_steps = 1000, 100\n",
    "lrs = [warmup_cosine_schedule(s, warmup_steps, total_steps) for s in range(total_steps)]\n",
    "\n",
    "plt.figure(figsize=(12, 4))\n",
    "plt.plot(lrs, linewidth=2, color='#2196F3')\n",
    "plt.axvline(x=warmup_steps, color='red', linestyle='--', label=f'Warmup结束 (step {warmup_steps})')\n",
    "plt.xlabel('Training Step', fontsize=13)\n",
    "plt.ylabel('Learning Rate', fontsize=13)\n",
    "plt.title('Warmup + Cosine Annealing (LLM 训练标配)', fontsize=15, fontweight='bold')\n",
    "plt.legend(fontsize=12)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout(), plt.show()"
   ]
  },
