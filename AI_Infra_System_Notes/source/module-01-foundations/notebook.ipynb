    "---\n",
    "## 6. 优化器——SGD / Adam / AdamW 可视化对比"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 在简单的二次函数上比较优化器\n",
    "def f(w1, w2):\n",
    "    return w1**2 + 10 * w2**2  # 一个方向的曲率是另一个的10倍 → 不良条件!\n",
    "\n",
    "def train(optimizer_class, lr, steps=30):\n",
    "    w = torch.tensor([8.0, 8.0], requires_grad=True)\n",
    "    opt = optimizer_class([w], lr=lr)\n",
    "    path = [w.detach().clone().numpy()]\n",
    "    for _ in range(steps):\n",
    "        opt.zero_grad()\n",
    "        loss = f(w[0], w[1])\n",
    "        loss.backward()\n",
    "        opt.step()\n",
    "        path.append(w.detach().clone().numpy())\n",
    "    return np.array(path)\n",
    "\n",
    "# 训练并绘图\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 4.5))\n",
    "configs = [\n",
    "    ('SGD', torch.optim.SGD, 0.02),\n",
    "    ('SGD+Momentum', lambda p, lr: torch.optim.SGD(p, lr=lr, momentum=0.9), 0.02),\n",
    "    ('Adam', torch.optim.Adam, 0.3),\n",
    "]\n",
    "\n",
    "for ax, (name, opt_cls, lr) in zip(axes, configs):\n",
    "    path = train(opt_cls, lr, steps=30)\n",
    "    ax.plot(path[:, 0], path[:, 1], 'o-', markersize=4, linewidth=1.5, color='#2196F3')\n",
    "    ax.scatter([0], [0], s=200, marker='*', color='red', zorder=10, edgecolors='black')\n",
    "    ax.set_xlim(-10, 10), ax.set_ylim(-10, 10)\n",
    "    ax.set_xlabel('w1'), ax.set_ylabel('w2')\n",
    "    ax.set_title(f'{name}\\nlr={lr}', fontweight='bold')\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle('优化器在不良条件函数上的收敛路径\\nf(w1,w2)=w1²+10w2²', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "print(\"SGD: 在陡峭方向来回震荡, 平坦方向走得慢\")\n",
    "print(\"Momentum: 震荡被平滑, 收敛更快\")\n",
    "print(\"Adam: 自适应学习率, 每个参数独立调整步长, 最快\")"
   ]
  },
